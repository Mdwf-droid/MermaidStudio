<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MermaidStudio.UI.Avalonia.Controls.NodeControl"
             x:CompileBindings="False"
             Width="120"
             Height="50">

	<Grid>
		<!-- Rectangle / Rounded -->
		<Border x:Name="RootBorder"
                Background="#2D2D30"
                BorderBrush="#6A6A6A"
                BorderThickness="2"
                CornerRadius="0"
                IsVisible="True"/>

		<!-- Decision -->
		<Polygon x:Name="DecisionShape"
                 Points="60,0 120,25 60,50 0,25"
                 Fill="#2D2D30"
                 Stroke="#6A6A6A"
                 StrokeThickness="2"
                 IsVisible="False"/>

		<!-- Circle -->
		<Ellipse x:Name="CircleShape"
                 Width="72"
                 Height="48"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Fill="#2D2D30"
                 Stroke="#6A6A6A"
                 StrokeThickness="2"
                 IsVisible="False"/>

		<!-- Label -->
		<TextBlock x:Name="LabelText"
                   Text="{Binding Label}"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"/>

		<!-- Port droit actif -->
		<Ellipse x:Name="RightPort"
                 Width="8"
                 Height="8"
                 Fill="#AAAAAA"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Margin="0,0,-4,0"
                 Cursor="Cross"
                 PointerPressed="OnRightPortPressed"
                 PointerMoved="OnRightPortMoved"
                 PointerReleased="OnRightPortReleased"/>
	</Grid>
</UserControl>
