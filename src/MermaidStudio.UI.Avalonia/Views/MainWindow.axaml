<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MermaidStudio.UI.Avalonia.Views.MainWindow"
        x:CompileBindings="False"
        Width="1200"
        Height="800"
        Title="MermaidStudio"
        Background="#1E1E1E">

	<Grid RowDefinitions="Auto,*">

		<Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1"
                Padding="8">
			<TextBlock Text="MermaidStudio — S4 Preview de lien"
                       Foreground="White"/>
		</Border>

		<Canvas x:Name="EditorCanvas"
                Grid.Row="1"
                Background="#00000000"
                PointerPressed="OnCanvasPressed"
                PointerMoved="OnCanvasMoved"
                PointerReleased="OnCanvasReleased"/>
	</Grid>
</Window>
