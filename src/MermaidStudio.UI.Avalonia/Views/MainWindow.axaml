<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MermaidStudio.UI.Avalonia.Views.MainWindow"
        x:CompileBindings="False"
        Width="1400"
        Height="800"
        Title="MermaidStudio"
        Background="#1E1E1E"
        KeyDown="OnWindowKeyDown">

	<Grid RowDefinitions="Auto,*"
          ColumnDefinitions="*,380">

		<!-- Barre haute -->
		<Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#252526"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1"
                Padding="8">
			<DockPanel>
				<TextBlock Text="MermaidStudio — S15 Bézier edges"
                           Foreground="White"
                           VerticalAlignment="Center"/>

				<StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8">

					<TextBlock Text="Direction:"
                               Foreground="White"
                               VerticalAlignment="Center"/>

					<ComboBox x:Name="FlowDirectionComboBox"
                              Width="90"
                              SelectedIndex="0"
                              SelectionChanged="OnFlowDirectionChanged">
						<ComboBoxItem Content="LR" />
						<ComboBoxItem Content="TB" />
						<ComboBoxItem Content="RL" />
						<ComboBoxItem Content="BT" />
					</ComboBox>

					<Button Content="Export Mermaid"
                            Click="OnExportMermaidClicked"/>
				</StackPanel>
			</DockPanel>
		</Border>

		<!-- Canvas éditeur -->
		<Canvas x:Name="EditorCanvas"
                Grid.Row="1"
                Grid.Column="0"
                Background="#00000000"
                PointerPressed="OnCanvasPressed"
                PointerMoved="OnCanvasMoved"
                PointerReleased="OnCanvasReleased"/>

		<!-- Panneau droit -->
		<Border Grid.Row="1"
                Grid.Column="1"
                Background="#1B1B1B"
                BorderBrush="#333333"
                BorderThickness="1,0,0,0"
                Padding="8">
			<Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,16,Auto,Auto,Auto,Auto,Auto,Auto,16,Auto,*">

				<!-- Node -->
				<TextBlock Text="Selected node label"
                           Foreground="White"/>

				<TextBox x:Name="SelectedNodeLabelTextBox"
                         Grid.Row="1"
                         Margin="0,8,0,0"
                         IsEnabled="False"/>

				<Button x:Name="ApplyNodeLabelButton"
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        Content="Apply Label"
                        IsEnabled="False"
                        Click="OnApplyNodeLabelClicked"/>

				<ComboBox x:Name="SelectedNodeStyleComboBox"
                          Grid.Row="3"
                          Margin="0,8,0,0"
                          IsEnabled="False"
                          SelectedIndex="0">
					<ComboBoxItem Content="Rectangle" />
					<ComboBoxItem Content="Rounded" />
					<ComboBoxItem Content="Decision" />
					<ComboBoxItem Content="Circle" />
				</ComboBox>

				<Button x:Name="ApplyNodeStyleButton"
                        Grid.Row="4"
                        Margin="0,8,0,0"
                        Content="Apply Node Style"
                        IsEnabled="False"
                        Click="OnApplyNodeStyleClicked"/>

				<!-- Edge -->
				<TextBlock Grid.Row="6"
                           Text="Selected edge label"
                           Foreground="White"/>

				<TextBox x:Name="SelectedEdgeLabelTextBox"
                         Grid.Row="7"
                         Margin="0,8,0,0"
                         IsEnabled="False"/>

				<Button x:Name="ApplyEdgeLabelButton"
                        Grid.Row="8"
                        Margin="0,8,0,0"
                        Content="Apply Edge Label"
                        IsEnabled="False"
                        Click="OnApplyEdgeLabelClicked"/>

				<ComboBox x:Name="SelectedEdgeStyleComboBox"
                          Grid.Row="9"
                          Margin="0,8,0,0"
                          IsEnabled="False"
                          SelectedIndex="0">
					<ComboBoxItem Content="Default" />
					<ComboBoxItem Content="Dashed" />
					<ComboBoxItem Content="Thick" />
				</ComboBox>

				<ComboBox x:Name="SelectedEdgeDirectionComboBox"
                          Grid.Row="10"
                          Margin="0,8,0,0"
                          IsEnabled="False"
                          SelectedIndex="0">
					<ComboBoxItem Content="Forward" />
					<ComboBoxItem Content="Reverse" />
				</ComboBox>

				<Button x:Name="ApplyEdgeStyleButton"
                        Grid.Row="11"
                        Margin="0,8,0,0"
                        Content="Apply Edge Style"
                        IsEnabled="False"
                        Click="OnApplyEdgeStyleClicked"/>

				<!-- Mermaid output -->
				<TextBlock Grid.Row="13"
                           Text="Mermaid output"
                           Foreground="White"/>

				<TextBox x:Name="MermaidOutputTextBox"
                         Grid.Row="14"
                         Margin="0,8,0,0"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
			</Grid>
		</Border>
	</Grid>
</Window>
